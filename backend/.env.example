# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/vaidya

# Security Tokens (Use long random strings in production)
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
# Legacy secret (if needed)
JWT_SECRET=your_legacy_secret

# Frontend URL (For CORS)
CLIENT_URL=http://localhost:5173

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: Admin Credentials for Seeding
ADMIN_EMAIL=admin@vaidya.com
ADMIN_PASSWORD=strong_password_here
